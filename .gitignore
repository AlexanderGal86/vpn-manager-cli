# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
env/
venv/
.venv/
*.egg-info/
dist_build/
build/

# PyInstaller
*.spec
build/
# dist/ is intentionally NOT ignored (contains distributables)

# Module output files (generated at runtime)
module1_collector/output/*.json
module2_tester/output/*.json
module3_connector/output/*.txt

# Keep .gitkeep files
!module1_collector/output/.gitkeep
!module2_tester/output/.gitkeep
!module3_connector/output/.gitkeep

