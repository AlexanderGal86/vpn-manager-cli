@echo off
setlocal EnableDelayedExpansion
title VPN/Proxy Manager Setup
color 0B

echo.
echo  =============================================================
echo   VPN / PROXY MANAGER  ^|  Windows Setup
echo  =============================================================
echo.

:: Check admin rights
net session >nul 2>&1
if %errorLevel% NEQ 0 (
    echo  [!] Requires administrator rights. Relaunching...
    powershell -Command "Start-Process cmd -ArgumentList '/c ""%~f0""' -Verb RunAs"
    exit /b
)

:: Find Python
echo  [*] Looking for Python...
set PYTHON_CMD=
python --version >nul 2>&1
if %errorLevel% EQU 0 (
    for /f "tokens=*" %%v in ('python --version 2^>^&1') do set PYVER=%%v
    echo  [+] Found: !PYVER!
    set PYTHON_CMD=python
    goto :extract
)
py --version >nul 2>&1
if %errorLevel% EQU 0 (
    for /f "tokens=*" %%v in ('py --version 2^>^&1') do set PYVER=%%v
    echo  [+] Found (py launcher): !PYVER!
    set PYTHON_CMD=py
    goto :extract
)
echo  [!] Python not found.
echo  Install: https://www.python.org/downloads/
echo  Or run:  winget install Python.Python.3.12
set /p CHOICE="  Open python.org? [Y/n] > "
if /i "!CHOICE!" NEQ "n" start https://www.python.org/downloads/
pause & exit /b 1

:extract
echo  [*] Extracting installer...
