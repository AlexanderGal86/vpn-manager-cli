@echo off
setlocal EnableDelayedExpansion
title VPN/Proxy Manager — Setup
color 0B

echo.
echo  =============================================================
echo   VPN / PROXY MANAGER  ^|  Windows Setup
echo  =============================================================
echo.

:: ── Проверка прав администратора ─────────────────────────────
net session >nul 2>&1
if %errorLevel% NEQ 0 (
    echo  [!] Требуются права администратора.
    echo      Перезапускаем от имени администратора...
    echo.
    powershell -Command "Start-Process cmd -ArgumentList '/c \"%~f0\"' -Verb RunAs"
    exit /b
)

:: ── Проверка наличия Python ───────────────────────────────────
echo  [*] Поиск Python...
python --version >nul 2>&1
if %errorLevel% EQU 0 (
    for /f "tokens=*" %%v in ('python --version 2^>^&1') do set PYVER=%%v
    echo  [+] Найден: !PYVER!
    goto :run_installer
)

py --version >nul 2>&1
if %errorLevel% EQU 0 (
    for /f "tokens=*" %%v in ('py --version 2^>^&1') do set PYVER=%%v
    echo  [+] Найден (py launcher): !PYVER!
    set PYTHON_CMD=py
    goto :run_installer
)

:: ── Python не найден — предлагаем установить ─────────────────
echo.
echo  [!] Python не обнаружен в системе.
echo.
echo  Варианты установки:
echo   1. Скачать с официального сайта: https://www.python.org/downloads/
echo      Минимальная версия: Python 3.10
echo      ВАЖНО: поставьте галочку "Add Python to PATH"
echo.
echo   2. Установить через Microsoft Store:
echo      Откройте PowerShell и выполните:
echo      winget install Python.Python.3.12
echo.
set /p CHOICE="  Открыть python.org в браузере? [Y/n] > "
if /i "!CHOICE!" NEQ "n" (
    start https://www.python.org/downloads/
)
echo.
echo  После установки Python запустите setup.bat повторно.
pause
exit /b 1

:run_installer
:: ── Извлечение и запуск install.py через PowerShell ──────────
if not defined PYTHON_CMD set PYTHON_CMD=python

echo.
echo  [*] Распаковка установщика...

